# Required: Nova API credentials
NOVA_API_KEY=
NOVA_BASE_URL=https://api.nova.amazon.com/v1

# Optional: Public origin used when Nova needs to fetch uploaded images
# Example with tunnel: https://abcd.loca.lt
NEXT_PUBLIC_API_URL=

# Optional: Local disk storage for temporary uploads
LINGOLENS_UPLOAD_DIR=/tmp/lingolens-uploads

# Optional: Enable UI debug panel by default
NEXT_PUBLIC_DEBUG=false
